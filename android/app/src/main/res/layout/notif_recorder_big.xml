<?xml version="1.0" encoding="utf-8"?>
<!-- Notif de contrôle ARENA — vue DÉPLIÉE (DecoratedCustomViewStyle : en-tête
     app + petite icône ajoutés par le système au-dessus ; les actions standard
     — ex. « Envoyer le code » HOME avec réponse directe — apparaissent en
     dessous). Statut + compteur, puis rangée de pastilles d'action colorées.
     Chaque pastille reçoit son PendingIntent via setOnClickPendingIntent. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:paddingTop="2dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/notif_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="2"
            android:ellipsize="end"
            android:textAppearance="@style/TextAppearance.Compat.Notification.Info" />

        <Chronometer
            android:id="@+id/notif_chrono"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textAppearance="@style/TextAppearance.Compat.Notification.Time" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <!-- Arrêter (rouge) -->
        <LinearLayout
            android:id="@+id/notif_btn_stop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_notif_pill_stop"
            android:paddingTop="9dp"
            android:paddingBottom="9dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_notif_stop"
                android:importantForAccessibility="no" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Arrêter"
                android:textColor="@color/notif_btn_label"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Ouvrir (bleu) -->
        <LinearLayout
            android:id="@+id/notif_btn_open"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_notif_pill_open"
            android:paddingTop="9dp"
            android:paddingBottom="9dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_notif_open"
                android:importantForAccessibility="no" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Ouvrir"
                android:textColor="@color/notif_btn_label"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Copier (cyan) — AWAY seulement, masqué par défaut -->
        <LinearLayout
            android:id="@+id/notif_btn_code"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            android:background="@drawable/bg_notif_pill_code"
            android:paddingTop="9dp"
            android:paddingBottom="9dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_notif_copy"
                android:importantForAccessibility="no" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Copier"
                android:textColor="@color/notif_btn_label"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
