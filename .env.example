# ────────────────────────────────────────────────────────────────
# ARENA — Variables d'environnement (TEMPLATE)
# ────────────────────────────────────────────────────────────────
# Copier ce fichier vers .env et remplir avec tes vraies clés.
# Le fichier .env n'est PAS commité (cf. .gitignore).
# ────────────────────────────────────────────────────────────────

# ─── Build env ──────────────────────────────────────────────────
# Valeurs : development | staging | production
APP_ENV=development

# ─── Supabase ───────────────────────────────────────────────────
# Récupérer dans Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Supabase MCP — Personal Access Token (Dashboard → Account → Access Tokens)
# Utilisé par .mcp.json pour le serveur MCP Supabase
SUPABASE_ACCESS_TOKEN=YOUR_PERSONAL_ACCESS_TOKEN

# ─── Sentry (crash reporting) ───────────────────────────────────
# Récupérer dans Sentry → Project Settings → Client Keys (DSN)
# Laisser vide en dev pour désactiver Sentry localement.
SENTRY_DSN=

# ─── Agora (RTM présence + RTC streaming) ───────────────────────
# Récupérer dans Agora Console → Project Management.
# ⚠️ SEUL l'App ID est public. Le `App Certificate` NE DOIT JAMAIS
# être dans le .env client (côté serveur uniquement, secret Supabase
# de l'Edge Function `get_agora_token` — cf. PHASE 8.7).
AGORA_APP_ID=YOUR_AGORA_APP_ID

# ─── Google Sign-In (Social SSO) ────────────────────────────────
# Récupérer dans Google Cloud Console → APIs & Services → Credentials.
# Type "Web application" — c'est l'audience que Supabase vérifie sur l'idToken.
# Le Client Secret associé est stocké côté Supabase Dashboard, JAMAIS ici.
GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# ─── Firebase (FCM push) ────────────────────────────────────────
# Voir docs Firebase. Clés natives gérées via google-services.json
# (Android) / GoogleService-Info.plist (iOS) — pas dans .env.

# ─── CinetPay (paiements Afrique francophone) ───────────────────
# Activé en PHASE 11bis seulement
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# ─── NowPayments (crypto) ───────────────────────────────────────
# Activé en PHASE 11bis seulement
NOWPAYMENTS_API_KEY=
