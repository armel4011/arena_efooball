<?xml version="1.0" encoding="utf-8"?>
<!-- Notif de contrôle ARENA — vue REPLIÉE (DecoratedCustomViewStyle : le
     système ajoute l'en-tête app + petite icône au-dessus). Statut à gauche,
     compteur d'enregistrement (Chronometer natif) à droite. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <TextView
        android:id="@+id/notif_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:maxLines="1"
        android:ellipsize="end"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Info" />

    <Chronometer
        android:id="@+id/notif_chrono"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Time" />
</LinearLayout>
