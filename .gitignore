# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment
.env
.env.local
.env.*.local

# Flavor secrets / Firebase configs
google-services.json
GoogleService-Info.plist
firebase_options.dart
secrets/

# Android release signing — NE JAMAIS commiter le keystore prod, sa perte
# = perte de l'identité Play Store de l'app. Le keystore vit en local
# (sauvegarde chiffrée recommandée : 1Password / coffre-fort) ; sur CI
# il est injecté via un secret GitHub. Idem pour les mots de passe.
android/key.properties
android/app/*.keystore
android/app/*.jks

# Firebase Admin SDK / service account JSON — contient une clé RSA
# privée qui signe les appels FCM server-side. Doit vivre uniquement
# dans Supabase Edge Function Secrets (FIREBASE_SERVICE_ACCOUNT_JSON),
# jamais dans le repo. À sauvegarder hors-machine.
*-firebase-adminsdk-*.json
firebase-service-account*.json

# Sentry
.sentryclirc

# MCP — contains Supabase personal access token, never commit
.mcp.json

# Local debugging artifacts
error image/
.tmp_screenshots/
.claude_tmp_screen.png

# Android adb bugreports
bugreport*.zip
bugreport*.txt

# Android build artefacts (Gradle)
/android/build/

# Claude Code local config / state
.claude/

# Flutter DevTools generated config
devtools_options.yaml

# Supabase CLI local cache (auto-regenerated by `supabase` commands)
supabase/.temp/

# Outils CLI installés localement (Supabase CLI Windows, etc.) — binaires
# lourds (~200 Mo), non versionnés ; à récupérer via le release GitHub.
bin/

