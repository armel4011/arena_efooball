<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- =========================================================
         PHASE 8 — Anti-cheat + Streaming permissions
         ========================================================= -->

    <!-- Recording d'écran (MediaProjection API) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Bouton flottant overlay par-dessus eFootball -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- Required by flutter_overlay_window's foreground service on
         Android 14+ (targetSdk 34). The "specialUse" subtype must
         be paired with a textual rationale shown in app store reviews. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Détection du jeu lancé (app_usage) -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Notifications (Android 13+ runtime + foreground service notif) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Upload manuel d'une vidéo depuis la galerie (Android 13+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- Upload d'image dans le chat (Phase 12.5 item 3) — Android 13+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Android 14+ partial photo access — bonne pratique -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />
    <!-- Caméra pour prendre une photo depuis le chat (item 3) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Fallback Android 12 et inférieur -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Internet (Agora streaming + Supabase upload) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:label="@string/app_name"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- Deep link for Supabase password-recovery email — PHASE 2.
                 Mirrors `kResetPasswordRedirect` in `auth_providers.dart`. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data
                    android:scheme="com.arena.app"
                    android:host="reset-password"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- PHASE 8.4 — flutter_overlay_window foreground service.
             Hosts the floating "ARENA recording" button rendered on
             top of eFootball. The "specialUse" subtype is the only
             FGS subtype that fits an anti-cheat overlay on
             Android 14+. -->
        <service
            android:name="flutter.overlay.window.flutter_overlay_window.OverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="anti_cheat_overlay_during_match" />
        </service>

        <!-- PHASE 8.6 — Custom MediaProjection-based recorder. Replaces
             the upstream flutter_screen_recording plugin so we can
             pick our own resolution (360p) and bitrate (~500 kbps)
             and keep proof clips well under 100 MB. -->
        <service
            android:name=".ArenaRecorderService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>

        <!-- PHASE 8.2 — Détection de l'installation des jeux ciblés.
             `installed_apps` interroge ces packages spécifiques sans
             requérir QUERY_ALL_PACKAGES (banni Play Store sauf cas
             validés). -->
        <package android:name="jp.konami.pesam" />        <!-- eFootball -->
        <package android:name="com.ea.gp.fifamobile" />   <!-- FIFA / EA FC Mobile -->
    </queries>
</manifest>
