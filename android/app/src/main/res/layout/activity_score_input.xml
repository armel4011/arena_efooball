<?xml version="1.0" encoding="utf-8"?>
<!-- Mini-dialogue de saisie du SCORE (ScoreInputActivity), ouvert depuis le
     bouton « Score » de la notif de contrôle — repli universel du bouton
     flottant (marche même sans permission de superposition : Pixel 9 / Android
     15). Symétrique de activity_room_code_input.xml. Le joueur vient de finir
     son match, il saisit son score et ses tirs au but éventuels. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Score du match"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Valider enregistre ton score et scelle la vidéo."
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/score_my"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:hint="Moi"
            android:importantForAutofill="no"
            android:inputType="number"
            android:maxLength="2"
            android:maxLines="1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:text=":"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/score_opp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:hint="Adversaire"
            android:importantForAutofill="no"
            android:inputType="number"
            android:maxLength="2"
            android:maxLines="1"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/score_via_pen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Décidé aux tirs au but (si égalité)"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/score_pen_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <EditText
            android:id="@+id/score_pen_my"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:hint="Mes TAB"
            android:importantForAutofill="no"
            android:inputType="number"
            android:maxLength="2"
            android:maxLines="1"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:text=":"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/score_pen_opp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:hint="Ses TAB"
            android:importantForAutofill="no"
            android:inputType="number"
            android:maxLength="2"
            android:maxLines="1"
            android:textSize="18sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/score_cancel"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Annuler" />

        <Button
            android:id="@+id/score_submit"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Valider"
            android:textColor="@color/notif_btn_code"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
