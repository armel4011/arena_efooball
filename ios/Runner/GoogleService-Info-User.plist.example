<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  TEMPLATE — copier vers GoogleService-Info-User.plist (ignoré par git)
  et remplir les valeurs depuis la console Firebase :
  Project settings > Your apps > iOS app (flavor "user", bundle com.arena.app).
  Le fichier réel n'est PAS commité (cf. .gitignore : GoogleService-Info-*.plist).
-->
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>YOUR_FIREBASE_IOS_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>YOUR_GCM_SENDER_ID</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.arena.app</string>
	<key>PROJECT_ID</key>
	<string>YOUR_FIREBASE_PROJECT_ID</string>
	<key>STORAGE_BUCKET</key>
	<string>YOUR_PROJECT.firebasestorage.app</string>
	<key>IS_ADS_ENABLED</key>
	<false></false>
	<key>IS_ANALYTICS_ENABLED</key>
	<false></false>
	<key>IS_APPINVITE_ENABLED</key>
	<true></true>
	<key>IS_GCM_ENABLED</key>
	<true></true>
	<key>IS_SIGNIN_ENABLED</key>
	<true></true>
	<key>GOOGLE_APP_ID</key>
	<string>YOUR_GOOGLE_APP_ID_IOS_USER</string>
</dict>
</plist>
